{
  "allowed_users": {
    "type": "string",
    "title": "生图权限白名单 (QQ号)",
    "description": "填入允许使用的QQ号，多个用英文逗号隔开。留空则默认全员可用。",
    "default": ""
  },
  "providers": {
    "description": "🔌 API 节点配置",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "模型名称 (多个用逗号隔开)", "type": "string", "default": "banana" },
        "timeout": { "description": "超时时间 (秒)", "type": "string", "default": "60" }
      }
    },
    "templates": {
      "openai_node": {
        "name": "➕ 添加生图节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "模型名称", "type": "string", "default": "banana" },
          "timeout": { "description": "超时时间", "type": "string", "default": "60" }
        }
      }
    },
    "default": []
  },
  "video_providers": {
    "description": "🎬 视频 API 节点配置 (后台挂机)",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "视频模型名称 (多个用逗号隔开)", "type": "string", "default": "sora" },
        "timeout": { "description": "长连接超时时间 (秒)", "type": "string", "default": "300" }
      }
    },
    "templates": {
      "openai_video_node": {
        "name": "➕ 添加视频节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "视频模型名称", "type": "string", "default": "sora" },
          "timeout": { "description": "长连接超时时间", "type": "string", "default": "300" }
        }
      }
    },
    "default": []
  },
  "chain_text2img": { "description": "🎨 常规画图链路 (如: node_1)", "type": "string", "default": "node_1" },
  "chain_selfie": { "description": "🤳 自拍专用链路 (需支持改图的节点)", "type": "string", "default": "node_1" },
  "chain_video": { "description": "🎞️ 视频生成链路 (如: video_node_1)", "type": "string", "default": "video_node_1" },
  "chain_optimizer": { "description": "🧠 副脑优化链路 (调用哪个节点来扩写提示词)", "type": "string", "default": "node_1" },
  "optimizer_model": { "description": "🧠 副脑指定模型 (推荐极速模型，如 gpt-4o-mini)", "type": "string", "default": "gpt-4o-mini" },
  "persona_name": { "description": "🎭 我的名字 (AI助理的人设称呼)", "type": "string", "default": "默认助理" },
  "persona_base_prompt": { "description": "📝 我的外貌特征 (英文正向提示词)", "type": "text", "default": "masterpiece, best quality, 1girl" },
  "persona_ref_image": { "description": "👤 形象/人脸参考图 (直接点击上传)", "type": "file", "default": "" }
}
